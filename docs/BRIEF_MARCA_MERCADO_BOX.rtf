\f0\b\fs48 \cf4 \cb3 \strokec4 1. Objetivo de este brief\cb1 \
\pard\pardeftab720\sa200\partightenfactor0

\f1\b0\fs24 \cf4 \cb3 Quiero usar este documento como base para una primera iteraci\'f3n de identidad visual para 
\f0\b \cf5 \strokec5 Mercado Box
\f1\b0 \cf4 \strokec4 .\cb1 \
\cb3 La idea no es cerrar todo de antemano ni limitar la creatividad, sino comunicar con claridad:\cb1 \
\pard\tx220\tx720\pardeftab720\li720\fi-720\sa120\partightenfactor0
\ls1\ilvl0\cf4 \cb3 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec4 qu\'e9 tipo de marca quiero construir\cb1 \
\ls1\ilvl0\cb3 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec4 qu\'e9 sensaci\'f3n quiero generar en la gente\cb1 \
\ls1\ilvl0\cb3 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec4 qu\'e9 elementos me interesa explorar\cb1 \
\ls1\ilvl0\cb3 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec4 qu\'e9 cosas me gustar\'eda evitar\cb1 \
\pard\pardeftab720\sa200\partightenfactor0
\cf4 \cb3 Me interesa que este brief funcione como una gu\'eda clara para tomar una referencia real que me gusta, entender por qu\'e9 me gusta, y desde ah\'ed proponer una soluci\'f3n mucho m\'e1s propia, con m\'e1s identidad y con m\'e1s fuerza de marca para Mercado Box.\cb1 \
\pard\pardeftab720\sa240\partightenfactor0

\f0\b\fs48 \cf4 \cb3 2. Contexto del proyecto\cb1 \
\pard\pardeftab720\sa200\partightenfactor0

\f1\b0\fs24 \cf4 \cb3 Estoy construyendo un e-commerce con ambici\'f3n de crecer fuerte en Argentina. La marca tiene que sentirse comercial, confiable, moderna y f\'e1cil de recordar.\cb1 \
\pard\pardeftab720\sa200\partightenfactor0

\f0\b \cf5 \cb9 \strokec5 Promesa central de la marca:
\f1\b0 \cf4 \strokec4  env\'edos gratis a todo el pa\'eds, seguros y en pocos d\'edas.\cb1 \
\pard\pardeftab720\sa200\partightenfactor0
\cf4 \cb3 No quiero que eso aparezca solamente como una promo o un banner. Quiero que esa promesa se sienta tambi\'e9n en la identidad visual.\cb1 \
\cb3 La marca deber\'eda transmitir, incluso antes de leer mucho texto, que:\cb1 \
\pard\tx220\tx720\pardeftab720\li720\fi-720\sa120\partightenfactor0
\ls2\ilvl0\cf4 \cb3 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec4 comprar es f\'e1cil\cb1 \
\ls2\ilvl0\cb3 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec4 el env\'edo llega bien\cb1 \
\ls2\ilvl0\cb3 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec4 la experiencia es confiable\cb1 \
\ls2\ilvl0\cb3 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec4 hay velocidad, orden y practicidad\cb1 \
\ls2\ilvl0\cb3 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec4 detr\'e1s hay una tienda seria, pero cercana\cb1 \
\pard\pardeftab720\sa240\partightenfactor0

\f0\b\fs48 \cf4 \cb3 3. Inspiraci\'f3n principal\cb1 \
\pard\pardeftab720\sa200\partightenfactor0

\f1\b0\fs24 \cf4 \cb3 La referencia que m\'e1s me inspira hoy es 
\f0\b \cf5 \strokec5 Mercado Top
\f1\b0 \cf4 \strokec4 : {\field{\*\fldinst{HYPERLINK "https://www.mercadotop.com.ar/"}}{\fldrslt \cf7 \strokec7 https://www.mercadotop.com.ar}}\cb1 \
\cb3 Lo que me gusta de esa referencia:\cb1 \
\pard\tx220\tx720\pardeftab720\li720\fi-720\sa120\partightenfactor0
\ls3\ilvl0\cf4 \cb3 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec4 se siente comercial y activa\cb1 \
\ls3\ilvl0\cb3 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec4 tiene energ\'eda de e-commerce real\cb1 \
\ls3\ilvl0\cb3 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec4 transmite acceso, promo y dinamismo\cb1 \
\ls3\ilvl0\cb3 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec4 visualmente es agradable\cb1 \
\ls3\ilvl0\cb3 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec4 da sensaci\'f3n de tienda con movimiento\cb1 \
\pard\pardeftab720\sa200\partightenfactor0
\cf4 \cb3 Lo que no quiero hacer:\cb1 \
\pard\tx220\tx720\pardeftab720\li720\fi-720\sa120\partightenfactor0
\ls4\ilvl0\cf4 \cb3 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec4 no quiero copiarla\cb1 \
\ls4\ilvl0\cb3 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec4 no quiero que Mercado Box parezca una variaci\'f3n de esa marca\cb1 \
\ls4\ilvl0\cb3 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec4 no quiero depender de una est\'e9tica prestada\cb1 \
\pard\pardeftab720\sa200\partightenfactor0
\cf4 \cb3 Mi sensaci\'f3n es que Mercado Top est\'e1 muy bien y se ve lindo, pero tambi\'e9n siento que a la marca le falta un poco m\'e1s de identidad, de personalidad propia y de branding m\'e1s memorable.\cb1 \
\cb3 Me gustar\'eda ir un paso m\'e1s all\'e1 con Mercado Box: tomar esa energ\'eda comercial como punto de partida, pero construir una marca m\'e1s \'fanica, m\'e1s reconocible y con m\'e1s car\'e1cter propio.\cb1 \
\pard\pardeftab720\sa240\partightenfactor0

\f0\b\fs48 \cf4 \cb3 4. Qu\'e9 quiero que sea Mercado Box\cb1 \
\pard\pardeftab720\sa200\partightenfactor0

\f1\b0\fs24 \cf4 \cb3 Mercado Box tiene que sentirse como una marca:\cb1 \
\pard\tx220\tx720\pardeftab720\li720\fi-720\sa120\partightenfactor0
\ls5\ilvl0\cf4 \cb3 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec4 cercana\cb1 \
\ls5\ilvl0\cb3 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec4 \'e1gil\cb1 \
\ls5\ilvl0\cb3 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec4 confiable\cb1 \
\ls5\ilvl0\cb3 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec4 amable\cb1 \
\ls5\ilvl0\cb3 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec4 moderna\cb1 \
\ls5\ilvl0\cb3 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec4 funcional\cb1 \
\ls5\ilvl0\cb3 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec4 comercial\cb1 \
\ls5\ilvl0\cb3 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec4 memorable\cb1 \
\pard\pardeftab720\sa200\partightenfactor0
\cf4 \cb3 No busco una marca fr\'eda, distante o demasiado corporativa. Tampoco busco algo demasiado infantil o exageradamente caricaturesco.\cb1 \
\cb3 La idea es encontrar un equilibrio entre:\cb1 \
\pard\tx220\tx720\pardeftab720\li720\fi-720\sa120\partightenfactor0
\ls6\ilvl0\cf4 \cb3 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec4 simpat\'eda\cb1 \
\ls6\ilvl0\cb3 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec4 simplicidad\cb1 \
\ls6\ilvl0\cb3 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec4 confianza\cb1 \
\ls6\ilvl0\cb3 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec4 velocidad\cb1 \
