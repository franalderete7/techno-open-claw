\outl0\strokewidth0 \strokec4 claridad comercial\cb1 \
\pard\pardeftab720\sa200\partightenfactor0
\cf4 \cb3 Si tuviera que resumirlo en una sola frase: 
\f0\b \cf5 \strokec5 Mercado Box deber\'eda verse como una marca que hace que comprar online y recibir un env\'edo sea algo f\'e1cil, seguro, lindo y r\'e1pido.
\f1\b0 \cf4 \cb1 \strokec4 \
\pard\pardeftab720\sa240\partightenfactor0

\f0\b\fs48 \cf4 \cb3 5. Significado del nombre\cb1 \
\pard\pardeftab720\sa200\partightenfactor0

\f1\b0\fs24 \cf4 \cb3 El nombre 
