# Core database
POSTGRES_DB=techno_open_claw
POSTGRES_USER=techno
POSTGRES_PASSWORD=aldegol
POSTGRES_PORT=5432
DATABASE_URL=postgres://techno:aldegol@postgres:5432/techno_open_claw
# Core API
API_HOST=0.0.0.0
API_PORT=4000
API_BEARER_TOKEN=aldegol
UPLOADS_DIR=/app/data/uploads
PUBLIC_API_BASE_URL=https://api.technostoresalta.com

# Cloudinary (optional). When set, Telegram /media/... images are uploaded on product create/update
# with public_id {CLOUDINARY_PRODUCTS_FOLDER}/{sku} (default: assets → Media Library folder "assets")
# and the product stores secure_url.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_PRODUCTS_FOLDER=assets

# Internal web -> API
INTERNAL_API_BASE_URL=http://api:4000
INTERNAL_API_BEARER_TOKEN=aldegol
WEB_PORT=3000

# Ollama / model runtime
# For Docker on the VPS, the API container reaches the host model through host.docker.internal.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3.5:cloud
# Reviewer uses the same Ollama host; model = OLLAMA_MODEL unless you set:
# OLLAMA_REVIEW_MODEL=
GROQ_API_KEY=

# Automatic conversation review (idle conversations vs n8n v18 workflow prompts in repo)
# Docker Compose mounts ./n8n → /app/review-repo/n8n and sets CONVERSATION_REVIEW_REPO_DIR=/app/review-repo for the API.
# On bare metal, point to repo root: CONVERSATION_REVIEW_REPO_DIR=/srv/techno-open-claw
CONVERSATION_REVIEW_ENABLED=true
CONVERSATION_REVIEW_INTERVAL_MINUTES=30
CONVERSATION_REVIEW_BATCH_SIZE=10
CONVERSATION_REVIEW_IDLE_MINUTES=20
# Optional: comma-separated Telegram chat IDs for review digests (falls back to TELEGRAM_ALLOWED_CHAT_IDS if empty)
CONVERSATION_REVIEW_TELEGRAM_CHAT_IDS=

# Telegram operator channel
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_BASE_URL=

# Cloudflare Tunnel (optional but recommended)
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_TUNNEL_HOST_API=api.aldegol.com
CLOUDFLARE_TUNNEL_HOST_WEB=ops.aldegol.com
CLOUDFLARE_TUNNEL_HOST_OPENCLAW=claw.aldegol.com

# GitHub deploy access (recommended for private repos)
GITHUB_REPO_SSH_URL=git@github.com:franalderete7/techno-open-claw.git
GITHUB_DEPLOY_KEY_PATH=/home/franalderete7/.ssh/techno-open-claw

# ManyChat / n8n bridge
MANYCHAT_API_KEY=
MANYCHAT_ACCOUNT_ID=
OPENCLAW_API_BASE_URL=http://api:4000
OPENCLAW_API_TOKEN=aldegol
# Optional JSON for v20 bot "TIENDA" block, e.g. {"name":"TechnoStore","store_address":"...","store_phone":"...","store_hours":"..."}
TECHNO_BOT_STORE_JSON=
# Optional override path for price list markdown (default: repo data/techno-pricelist-abril.md). API container: file must be under /app/data if you mount ./data.
TECHNO_PRICELIST_PATH=
SUPABASE_URL=http://api:4000
SUPABASE_KEY=aldegol
GEMINI_MODEL_SALES=models/gemini-2.5-flash

# n8n runtime / public webhooks
WEBHOOK_URL=https://n8n.technostoresalta.com/
N8N_HOST=n8n.technostoresalta.com
N8N_PROTOCOL=https
# Optional for n8n deploy/import scripts (e.g. import-n8n-v20.sh)
# N8N_CONTAINER_NAME=n8n-n8n-1
# N8N_API_BASE=http://127.0.0.1:5678
# N8N_API_USER=
# N8N_API_PASS=
# N8N_API_KEY=

# Storefront / payments
STORE_WHATSAPP_PHONE=543875319940
GALIOPAY_API_BASE_URL=https://pay.galio.app
GALIOPAY_CLIENT_ID=
GALIOPAY_API_KEY=
GALIOPAY_NOTIFICATION_URL=https://api.technostoresalta.com/webhooks/galiopay
GALIOPAY_SUCCESS_URL=https://technostoresalta.com/pago/exito
GALIOPAY_FAILURE_URL=https://technostoresalta.com/pago/error
GALIOPAY_SANDBOX=false
TALO_API_BASE_URL=https://api.talo.com.ar
TALO_USER_ID=
TALO_CLIENT_ID=
TALO_CLIENT_SECRET=
TALO_WEBHOOK_URL=https://api.technostoresalta.com/webhooks/talo
TALO_REDIRECT_URL=https://technostoresalta.com
TALO_SANDBOX=false

# Meta storefront / catalog
META_ACCESS_TOKEN=
META_CATALOG_ID=
META_PIXEL_ID=
META_CATALOG_FEED_TOKEN=
META_TEST_EVENT_CODE=
META_API_VERSION=v25.0
META_GRAPH_API_BASE=https://graph.facebook.com
